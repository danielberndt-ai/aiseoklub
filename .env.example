# Másold le .env néven helyi teszteléshez (a Vercel dashboardon külön kell
# beállítani ugyanezeket: Project Settings > Environment Variables).

# Resend – a személyre szabott riport-email kiküldéséhez.
# A RESEND_FROM domainjét előbb hitelesíteni kell a Resend felületén.
RESEND_API_KEY=
RESEND_FROM="AI SEO Klub <audit@aiseoklub.hu>"

# Google Sheets – a feliratkozók gyűjtéséhez, Apps Script webhookon át.
# A SECRET egy általad kitalált, hosszú véletlen szöveg: ugyanaznak kell
# szerepelnie a Vercelen és az Apps Script kódjában is.
SHEETS_WEBHOOK_URL=
SHEETS_WEBHOOK_SECRET=

# Upstash Redis – a napi 3 audit limit megbízható, több szerver-példány
# között is működő nyilvántartásához. Enélkül a limit csak egy-egy szerver-
# példányon belül, memóriában érvényesül.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
